`timescale 1 ps/ 1 ps

module uart (
	rx_in,
	sys_clk,
	rst,
	tx_fifo_en,
	rx_ready,
	tx_out,
	rx_fifo_empty,
	tx_fifo_full);
input 	rx_in;
input 	sys_clk;
input 	rst;
input 	tx_fifo_en;
input 	rx_ready;
output 	tx_out;
output 	rx_fifo_empty;
output 	tx_fifo_full;

// Design Ports Information
// tx_out	=>  Location: PIN_W10,	 I/O Standard: 2.5 V,	 Current Strength: Default
// rx_fifo_empty	=>  Location: PIN_V10,	 I/O Standard: 2.5 V,	 Current Strength: Default
// tx_fifo_full	=>  Location: PIN_B12,	 I/O Standard: 2.5 V,	 Current Strength: Default
// rst	=>  Location: PIN_C10,	 I/O Standard: 2.5 V,	 Current Strength: Default
// sys_clk	=>  Location: PIN_P11,	 I/O Standard: 2.5 V,	 Current Strength: Default
// rx_ready	=>  Location: PIN_C11,	 I/O Standard: 2.5 V,	 Current Strength: Default
// tx_fifo_en	=>  Location: PIN_D12,	 I/O Standard: 2.5 V,	 Current Strength: Default
// rx_in	=>  Location: PIN_V9,	 I/O Standard: 2.5 V,	 Current Strength: Default


